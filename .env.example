# MediaFlow — local development environment variables
# Each service also has its own .env.example under services/<name>/
# For docker-compose these are set directly in docker-compose.yml.

# ─── api-gateway ────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
UPLOAD_SERVICE_ADDR=localhost:8081
MEDIA_QUERY_SERVICE_ADDR=http://localhost:8086
SAGA_ORCHESTRATOR_ADDR=localhost:8082

# ─── upload-service ─────────────────────────────────────────────────────────
GRPC_ADDR=:50051
DB_DSN=postgres://postgres:postgres@localhost:5432/mediaflow?sslmode=disable
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=mediaflow
S3_REGION=us-east-1
KAFKA_BROKER=localhost:9092

# ─── media-query-service ────────────────────────────────────────────────────
# HTTP_ADDR=:8086  (conflicts with api-gateway above when running locally)
# DB_DSN=          (same as upload-service)

# ─── saga-orchestrator ──────────────────────────────────────────────────────
# GRPC_ADDR=:50051  (conflicts with upload-service above when running locally)
# DB_DSN=           (same as upload-service)

# ─── Infrastructure (docker-compose defaults) ───────────────────────────────
# Postgres:   localhost:5432  user=postgres  password=postgres  db=mediaflow
# Kafka:      localhost:9092
# LocalStack: localhost:4566  (S3)
