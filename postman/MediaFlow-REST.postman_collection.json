{
  "info": {
    "_postman_id": "f1a2b3c4-d5e6-7890-abcd-111111111111",
    "name": "MediaFlow — REST",
    "description": "REST endpoints exposed by api-gateway and media-query-service.\n\nThe collection is designed to be run sequentially: presign → upload to S3 → complete → query media. Test scripts automatically propagate uploadId, mediaId, and sagaId into the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "api-gateway",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/health",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "health"]
            },
            "description": "Basic liveness probe."
          },
          "response": []
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/ready",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "ready"]
            },
            "description": "Returns 200 only when downstream dependencies (Kafka, DB) are reachable."
          },
          "response": []
        },
        {
          "name": "Presign Upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    if (body.uploadId) pm.environment.set('uploadId', body.uploadId);",
                  "    if (body.url) pm.environment.set('presignedUrl', body.url);",
                  "    pm.test('uploadId is set', () => pm.expect(body.uploadId).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"demo-video.mp4\",\n  \"contentType\": \"video/mp4\",\n  \"sizeBytes\": 104857600\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/v1/uploads/presign",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "uploads", "presign"]
            },
            "description": "Request a presigned S3 PUT URL. The client should then upload the file directly to S3 using the returned URL and headers."
          },
          "response": []
        },
        {
          "name": "Complete Upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 202) {",
                  "    const body = pm.response.json();",
                  "    if (body.mediaId) pm.environment.set('mediaId', body.mediaId);",
                  "    if (body.sagaId) pm.environment.set('sagaId', body.sagaId);",
                  "    pm.test('mediaId is set', () => pm.expect(body.mediaId).to.be.a('string'));",
                  "    pm.test('sagaId is set', () => pm.expect(body.sagaId).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"etag\": \"\\\"d41d8cd98f00b204e9800998ecf8427e\\\"\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/v1/uploads/{{uploadId}}/complete",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "uploads", "{{uploadId}}", "complete"]
            },
            "description": "Confirm that the file was uploaded to S3. This creates the media aggregate, writes to the outbox, and starts the processing saga."
          },
          "response": []
        },
        {
          "name": "Get Media",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/media/{{mediaId}}",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "media", "{{mediaId}}"]
            },
            "description": "Retrieve the full media view including metadata, variants, and thumbnails. Proxied to media-query-service."
          },
          "response": []
        },
        {
          "name": "List Media",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/media?userId=user-1&status=COMPLETED&cursor=&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "media"],
              "query": [
                { "key": "userId", "value": "user-1" },
                { "key": "status", "value": "COMPLETED" },
                { "key": "cursor", "value": "" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "List media with optional filters and cursor-based pagination."
          },
          "response": []
        },
        {
          "name": "Get Playback URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/media/{{mediaId}}/playback",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "media", "{{mediaId}}", "playback"]
            },
            "description": "Get the HLS/DASH manifest URL for video playback."
          },
          "response": []
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/media/{{mediaId}}",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "media", "{{mediaId}}"]
            },
            "description": "Soft delete. Starts a delete saga that cleans up S3 objects, metadata, and projections."
          },
          "response": []
        },
        {
          "name": "Get Saga Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/v1/sagas/{{sagaId}}",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "sagas", "{{sagaId}}"]
            },
            "description": "Debug endpoint to inspect saga state machine, step history, and errors."
          },
          "response": []
        }
      ]
    },
    {
      "name": "media-query-service (direct)",
      "description": "Direct access to the CQRS read model. In production, these are proxied through api-gateway. Use during development to bypass the gateway.",
      "item": [
        {
          "name": "Get Media (direct)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{MEDIA_QUERY_BASE_URL}}/v1/media/{{mediaId}}",
              "host": ["{{MEDIA_QUERY_BASE_URL}}"],
              "path": ["v1", "media", "{{mediaId}}"]
            }
          },
          "response": []
        },
        {
          "name": "List Media (direct)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{MEDIA_QUERY_BASE_URL}}/v1/media?userId=user-1&cursor=&limit=20",
              "host": ["{{MEDIA_QUERY_BASE_URL}}"],
              "path": ["v1", "media"],
              "query": [
                { "key": "userId", "value": "user-1" },
                { "key": "cursor", "value": "" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Variants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{MEDIA_QUERY_BASE_URL}}/v1/media/{{mediaId}}/variants",
              "host": ["{{MEDIA_QUERY_BASE_URL}}"],
              "path": ["v1", "media", "{{mediaId}}", "variants"]
            },
            "description": "List transcoded renditions (HLS profiles) for a media."
          },
          "response": []
        },
        {
          "name": "Get Thumbnails",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{MEDIA_QUERY_BASE_URL}}/v1/media/{{mediaId}}/thumbnails",
              "host": ["{{MEDIA_QUERY_BASE_URL}}"],
              "path": ["v1", "media", "{{mediaId}}", "thumbnails"]
            },
            "description": "List generated thumbnails for a media."
          },
          "response": []
        }
      ]
    }
  ]
}
